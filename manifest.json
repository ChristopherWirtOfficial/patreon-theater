{
  "manifest_version": 3,
  "name": "Theater Mode for Patreon",
  "version": "1.0.0",
  "description": "Fit-to-viewport theater mode for the Patreon video player. Not affiliated with Patreon.",
  "homepage_url": "https://github.com/ChristopherWirtOfficial/patreon-theater",
  "permissions": ["scripting", "activeTab", "declarativeContent"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Toggle theater mode",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
